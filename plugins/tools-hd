import fetch from 'node-fetch'
import FormData from 'form-data'
import crypto from 'crypto'
import fs from 'fs'

const handler = async ({
    sock,
    m,
    from,
    participants,
    sender,
    args
}) => {

    // MODODADMIN
    let isBlockedGroup = false

    try {
        const db = JSON.parse(
            fs.readFileSync(
                './data/modoadmin.json',
                'utf8'
            )
        )

        isBlockedGroup = db[from]
    } catch {}

    const user = participants?.find(
        p => p.id === sender
    )

    const isAdmin =
        user?.admin === 'admin' ||
        user?.admin === 'superadmin'

    if (
        isBlockedGroup &&
        !isAdmin
    ) return

    const key = Buffer
        .from('c2FzdWtl', 'base64')
        .toString('utf8')

    const quoted =
        m.quoted ? m.quoted : m

    const mime =
        quoted?.msg?.mimetype ||
        quoted?.mimetype ||
        ''

    const urlTarget =
        args?.join(' ')?.trim()

    if (
        !urlTarget &&
        !/image\/(jpeg|jpg|png)/.test(mime)
    ) {
        return sock.sendMessage(from,{
            text:
`🖼️ Usa:

.hd (respondiendo imagen)`
        },{ quoted:m })
    }

    await sock.sendMessage(from,{
        react:{
            text:'⏳',
            key:m.key
        }
    })

    try {

        let finalUrl = urlTarget

        if (
            !finalUrl &&
            /image\/(jpeg|jpg|png)/.test(mime)
        ) {

            const imgBuffer =
                await quoted.download()

            const ext =
                mime.split('/')[1] || 'jpg'

            const filename =
                'img-' +
                crypto.randomBytes(8).toString('hex') +
                '.' + ext

            const form =
                new FormData()

            form.append(
                'file',
                imgBuffer,
                {
                    filename,
                    contentType: mime
                }
            )

            const upload =
                await fetch(
                    `https://api.evogb.org/tools/upload?key=${key}`,
                    {
                        method:'POST',
                        body:form,
                        headers:{
                            ...form.getHeaders()
                        }
                    }
                )

            const uploadJson =
                await upload.json()

            if (
                uploadJson.status &&
                uploadJson.url
            ) {
                finalUrl = uploadJson.url
            } else {
                throw new Error(
                    'Error subiendo imagen'
                )
            }
        }

        const res =
            await fetch(
                `https://api.evogb.org/tools/upscale?method=url&url=${encodeURIComponent(finalUrl)}&key=${key}`
            )

        const contentType =
            res.headers.get('content-type')

        if (
            contentType &&
            contentType.includes('application/json')
        ) {
            const error =
                await res.json()

            throw new Error(
                error.message ||
                'Error API'
            )
        }

        const buffer =
            await res.buffer()

        await sock.sendMessage(from,{
            image: buffer,
            caption:
`╭━━━〔 🕷️ REMINI 〕━━━⬣
┃
┃ ✅ Imagen mejorada
┃ ⚡ Calidad aumentada
╰━━━━━━━━━━━━━━━━⬣`
        },{ quoted:m })

        await sock.sendMessage(from,{
            react:{
                text:'✅',
                key:m.key
            }
        })

    } catch (err) {

        console.log(
            'REMINI ERROR:',
            err
        )

        await sock.sendMessage(from,{
            react:{
                text:'❌',
                key:m.key
            }
        })

        await sock.sendMessage(from,{
            text:
'❌ Error mejorando imagen.'
        },{ quoted:m })
    }
}

handler.command = ['hd']
handler.tags = ['tools']
handler.group = true
handler.menu = true

export default handler